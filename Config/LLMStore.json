	"promptTemplates": [
		{
			"id": "example.short.answer",
			"description": "Short answer template for the sample project.",
			"template": "User request: {prompt}\nAnswer briefly and mention that this is routed through LLM Store.",
			"variables": [
				"prompt"
			]
		},
		{
			"id": "example.asset.explain",
			"description": "Explains an Unreal asset or content item for artists and designers.",
			"template": "You are helping an Unreal Engine content team understand an asset.\n\nAsset notes:\n{prompt}\n\nReturn: purpose, likely owner, risk, and one useful next action.",
			"variables": [
				"prompt"
			]
		},
		{
			"id": "example.docs.summarize",
			"description": "Summarizes documentation into decisions and next steps.",
			"template": "Summarize the following Unreal project documentation for a busy technical lead.\n\nDocumentation:\n{prompt}\n\nReturn: summary, important decisions, missing information, and follow-up tasks.",
			"variables": [
				"prompt"
			]
		},
		{
			"id": "example.npc.dialogue",
			"description": "Drafts a short in-character NPC line from narrative context.",
			"template": "You are drafting placeholder NPC dialogue for an Unreal game prototype.\n\nNarrative context:\n{prompt}\n\nReturn three short dialogue options with different emotional tones.",
			"variables": [
				"prompt"
			]
		},
		{
			"id": "example.code.review",
			"description": "Reviews a small C++ or Blueprint-adjacent code snippet.",
			"template": "Review this Unreal Engine implementation note or snippet.\n\nContent:\n{prompt}\n\nReturn: likely issue, severity, safer pattern, and test idea.",
			"variables": [
				"prompt"
			]
		},
		{
			"id": "example.qa.testplan",
			"description": "Turns a feature note into a compact QA checklist.",
			"template": "Create a practical QA checklist for this Unreal feature.\n\nFeature note:\n{prompt}\n\nReturn: smoke tests, edge cases, regression risks, and automation ideas.",
			"variables": [
				"prompt"
			]
		}
	],
